---
import PhotoAside from "../components/PhotoAside.astro";
import Head from "../components/Head.astro";
import FooterCommon from "../components/FooterCommon.astro";
import type Background from "../interfaces/Background";
import Resume from "../components/Resume.astro";
import Links from "../components/Links.astro";

const { ME_NAME, ME_IMAGE } = import.meta.env;
const DESCRIPTION = `Hi! I'm ${ME_NAME}, welcome to my personal website!`;

/**
 * Handle background
 *
 * Returns empty url if .json is not found
 */
const loadBackground = async (): Promise<Background> => {
  try {
    const background = await import('../data/background.json');
    return background.default;
  } catch {
    return {
      url: ''
    }
  }
}

const background = await loadBackground();
---

<html lang="en">
  <Head title="Home" description={DESCRIPTION} name={ME_NAME} />
  <body>
    <section class="hero is-fullheight" style={{
      "background": `url("${background.url}")`,
      "background-position": "center",
      "background-repeat": "no-repeat",
      "background-size": "cover"
    }}>
      <div class="hero-body">
        <div class="container has-text-centered">
          <div class="columns is-centered">
            <div class="column is-half">
              <div class="box">
                <PhotoAside src={ME_IMAGE} alt={ME_NAME} l_size="narrow" r_size="narrow" ratio="128x128" rounded>
                  <p class="title">Welcome!</p>
                  <p class="subtitle">
                    <span>I'm {ME_NAME}</span>
                  </p>
                </PhotoAside>
                <nav class="level">
                  <div class="level-item">
                    <Links />
                  </div>
                  <div class="level-item">
                    <Resume />
                  </div>
                </nav>
              </div>
            </div>
          </div>
          <div class="columns is-centered is-vcentered">
            <div class="column is-half">
              <div class="box">
                {background.author && (
                  <p>Background photo by {background.author.name} on <a href={background.author.url} target="_blank" rel="nofollow">{background.author.platform}</a></p>
                )}
                <FooterCommon />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </body>
</html>

---
import Default from "../layouts/Default.astro";
import type Service from "../interfaces/Service";
import Card from "../components/Card.astro";
import Language from "../helpers/Language";

const getServices = async (): Promise<Service[]> => {
  try {
    const services = await import("../data/services.json");
    return services.default;
  } catch {
    return [];
  }
};

const services = await getServices();
---

<Default title="Services" description="List of services that I'm hosting">
  <p class="title" slot="header">Services</p>
  <p class="has-text-centered">
    This is a list with all the public instances that I host on this server
  </p>
  <hr />
  <div class="columns is-centered is-vcentered is-multiline">
    {
      services.map((item) => {
        return (
          <div class="column is-one-quarter" data-name={item.name}>
            <Card>
              {item.image && (
                <figure slot="image" class="image">
                  <img alt={item.name} src={item.image} />
                </figure>
              )}
              <div class="content" slot="content">
                <p class="title">
                  {item.name}{" "}
                  {item.beta && <small class="has-text-danger">(beta)</small>}
                </p>
                <p class="subtitle">{item.description}</p>
                {item.tags && (
                  <div class="tags">
                    {item.tags.map((tag) => (
                      <span class="tag is-rounded is-primary">{tag}</span>
                    ))}
                  </div>
                )}
                {item.langs && (
                  <div class="field is-grouped is-grouped-multiline">
                    {item.langs.map((lang) => (
                      <div class="control">
                        <div class="tags has-addons">
                          <span class="tag is-primary">{lang}</span>
                          <span class="tag is-info">{Language.flag(lang)}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
              <a
                href={item.url}
                class="card-footer-item"
                slot="footer"
                target="_blank"
              >
                Go
              </a>
              {item.source && (
                <a
                  href={item.source}
                  class="card-footer-item"
                  slot="footer"
                  target="_blank"
                >
                  Source
                </a>
              )}
            </Card>
          </div>
        );
      })
    }
  </div>
</Default>
